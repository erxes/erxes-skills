```bash
mkdir -p ~/erxes-proposals
_DATE=$(date +%Y-%m-%d)
_YEAR=$(date +%Y)
_MONTH=$(date +%m)
_DAY=$(date +%d)
echo "PROPOSAL_DATE=$_DATE"
echo "PROPOSAL_YEAR=$_YEAR"
# Set dynamic start date for roadmap (next Monday)
_ROADMAP_START=$(date -v+monday +%Y-%m-%d 2>/dev/null || date -d "next monday" +%Y-%m-%d 2>/dev/null || echo "$_DATE")
