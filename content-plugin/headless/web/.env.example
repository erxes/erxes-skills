# GitHub — for cloning the starter repo and pushing generated sites
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
STARTER_REPO_URL=https://github.com/pages-web/erxes-web-starter

# Vercel — for deployment
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_vercel_org_id_here

# erxes — filled from site.config.json, can also be set here to override
ERXES_ENDPOINT=https://your-tenant.next.erxes.io/gateway/graphql
ERXES_APP_TOKEN=your_erxes_app_token_here
NEXT_PUBLIC_ERXES_ENDPOINT=https://your-tenant.next.erxes.io/gateway/graphql
ERXES_CMS_ID=your_erxes_cms_id_here
ERXES_LANGUAGE=en
